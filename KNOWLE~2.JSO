{"id": "chunk_00152", "text": "# FILE: Calendar .docx # CATEGORY: Calendar / Schedule # SIZE: 14340 bytes Calendar = ADDCOLUMNS( CALENDAR(DATE(2025,1,1), DATE(2026,12,31)), \"Year\", YEAR([Date]), \"Month No\", MONTH([Date]), \"Month Name\", FORMAT([Date], \"MMM\"), \"Year Month\", FORMAT([Date], \"YYYY-MM\"), \"Quarter\", \"Q\" & ROUNDUP(MONTH([Date]) / 3, 0) )", "metadata": {"source": "Calendar .docx", "category": "Calendar / Schedule", "owner": "Mohamed Fekri Soliman", "pii_status": "anonymized"}}
